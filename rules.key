\functions {
    boolean created(Heap, java.lang.Object);
}
\rules {
    createdDefinition {
        \schemaVar \term Heap heap;
        \schemaVar \term java.lang.Object obj;

        \find(created(heap, obj))
        \replacewith(boolean::select(heap, obj, java.lang.Object::<created>))

        \heuristics(simplify)
    };

    \lemma
    bsum_num_of_eq0 {
        \schemaVar \formula phi;
        \schemaVar \term int i0;
        \schemaVar \term int i2;
        \schemaVar \variables int uSub;

        \find(bsum{uSub;}(i0, i2, \if(phi) \then(1) \else(0)))
        \varcond(\notFreeIn(uSub, i0), \notFreeIn(uSub, i2))
        \add(bsum{uSub;}(i0, i2, \if(phi) \then(1) \else(0)) = 0 ->
            !(\exists uSub; (i0 <= uSub & uSub < i2 & phi)) ==>)
    };

    \lemma
    bsum_num_of_gt1 {
        \schemaVar \formula phi;
        \schemaVar \term int i0;
        \schemaVar \term int i2;
        \schemaVar \variables int uSub;
        \schemaVar \variables int uSub2;

        \find(bsum{uSub;}(i0, i2, \if(phi) \then(1) \else(0)))
        \varcond(\notFreeIn(uSub, i0), \notFreeIn(uSub, i2))
        \varcond(\notFreeIn(uSub2, i0), \notFreeIn(uSub2, i2))
        \varcond(\notFreeIn(uSub2, phi))
        \varcond(\notFreeIn(uSub, uSub2), \notFreeIn(uSub2, uSub))
        \add(bsum{uSub;}(i0, i2, \if(phi) \then(1) \else(0)) > 1 ->
            \exists uSub; (i0 <= uSub & uSub < i2 & phi &
            (\exists uSub2; (uSub2 != uSub & {\subst uSub; uSub2}(i0 <= uSub & uSub < i2 & phi)))) ==>)
    };
}