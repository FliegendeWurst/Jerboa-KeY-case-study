      (rule "notLeft" (formula "10"))
      (rule "notLeft" (formula "9"))
      (rule "close" (formula "13") (ifseqformula "1"))
   )
)
(branch "Null Reference (_rule = null)"
    (builtin "One Step Simplification" (formula "1") (ifInst ""  (formula "12")))
   (rule "closeFalse" (formula "1"))
)
)
}
